generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ServiceCategory {
  NAILS
  TOE_NAILS
  LASHES
  EYEBROWS
  PEDICURE
  MANICURE
  ADD_ONS
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum GenderPricing {
  WOMEN
  MEN
  UNISEX
}

enum NotificationType {
  APPOINTMENT_REMINDER
  DEPOSIT_CONFIRMED
  REVIEW_REQUEST
  WELCOME
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
}

enum AdminNotificationType {
  NEW_BOOKING
  DEPOSIT_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  NEW_CLIENT
  LATE_CANCELLATION
  REFUND_ISSUED
}

model SalonSettings {
  id                  String   @id @default("default")
  businessName        String   @default("Dollhouse Lounge")
  contactEmail        String   @default("bookings@dollhouselounge.com")
  depositPercentage   Int      @default(50)
  cancellationHours   Int      @default(48)
  bufferMinutes       Int      @default(15)
  leadTimeHours       Int      @default(24)
  trustpilotUrl       String   @default("")
  instagramUrl        String   @default("")
  tiktokUrl           String   @default("")
  facebookUrl         String   @default("")
  logoUrl             String?
  emailBookingConfirm Boolean  @default(true)
  emailReminder       Boolean  @default(true)
  emailReviewRequest  Boolean  @default(true)
  emailCancellation   Boolean  @default(true)
  templateBookingConfirmSubject String?
  templateBookingConfirmBody    String?
  templateReminderSubject       String?
  templateReminderBody          String?
  templateReviewSubject         String?
  templateReviewBody            String?
  templateCancellationSubject   String?
  templateCancellationBody      String?
  updatedAt           DateTime @updatedAt
}

model BlockedTimeSlot {
  id        String   @id @default(cuid())
  date      DateTime
  startTime String
  endTime   String
  reason    String?
  createdAt DateTime @default(now())

  @@index([date])
}

model AdminNotification {
  id        String                @id @default(cuid())
  type      AdminNotificationType
  title     String
  message   String
  read      Boolean               @default(false)
  bookingId String?
  userId    String?
  linkPath  String?
  createdAt DateTime              @default(now())

  @@index([read])
  @@index([createdAt])
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  phone        String
  avatarUrl     String?
  internalNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings           Booking[]
  notifications      Notification[]
  passwordResetTokens PasswordResetToken[]

  @@index([email])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean          @default(false)
  bookingId String?
  createdAt DateTime         @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([read])
}

model Service {
  id          String          @id @default(cuid())
  name        String
  description String?
  pricePence  Int
  category    ServiceCategory
  durationMin Int             @default(60)
  gender      GenderPricing?
  isActive    Boolean         @default(true)
  isAddOn     Boolean         @default(false)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  bookingServices BookingService[]
  bookingAddOns   BookingAddOn[]

  @@index([category])
  @@index([isActive])
}

model BusinessHours {
  id        String  @id @default(cuid())
  dayOfWeek Int     @unique // 0 = Sunday, 6 = Saturday
  openTime  String  // "09:00"
  closeTime String  // "18:00"
  isClosed  Boolean @default(false)
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      DateTime @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Booking {
  id                    String        @id @default(cuid())
  reference             String        @unique
  status                BookingStatus @default(PENDING_PAYMENT)
  userId                String?

  firstName             String
  lastName              String
  email                 String
  phone                 String
  notes                 String?
  internalNotes         String?
  isManualBooking       Boolean       @default(false)

  appointmentDate       DateTime
  appointmentTime       String        // "10:00"
  durationMin           Int

  totalPence            Int
  depositPence          Int
  remainingPence        Int

  stripePaymentIntentId String?       @unique
  depositPaidAt         DateTime?
  policyAccepted        Boolean       @default(false)

  cancelledAt           DateTime?
  cancellationReason    String?
  refundPence           Int?

  confirmationEmailSent Boolean       @default(false)
  reviewEmailSent       Boolean       @default(false)

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  services      BookingService[]
  addOns        BookingAddOn[]
  notifications Notification[]

  @@index([appointmentDate])
  @@index([status])
  @@index([email])
  @@index([userId])
}

model BookingService {
  id        String @id @default(cuid())
  bookingId String
  serviceId String
  pricePence Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
}

model BookingAddOn {
  id        String @id @default(cuid())
  bookingId String
  serviceId String
  pricePence Int

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([bookingId, serviceId])
}
