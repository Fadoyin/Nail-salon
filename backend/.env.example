# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Auth
JWT_SECRET=your-long-random-secret-here
JWT_EXPIRES_IN=7d

# Database (SQLite for dev — swap to PostgreSQL in production)
DATABASE_URL="file:./dev.db"

# Stripe
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email (SMTP — use Gmail app password, SendGrid, or Resend SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Dollhouse Lounge <bookings@dollhouselounge.com>"

# Salon settings
SALON_TIMEZONE=Europe/London
DEPOSIT_PERCENTAGE=50
CANCELLATION_HOURS=48
TRUSTPILOT_REVIEW_URL=https://www.trustpilot.com/review/dollhouselounge.com

# Admin (seeded on first setup — change password in production!)
ADMIN_EMAIL=owner@dollhouselounge.com
ADMIN_PASSWORD=changeme123
ADMIN_NAME=Salon Owner
